ted to work with you!\"\n    ],\n    typeSpeed: 50,\n    backSpeed: 30,\n    loop: true,\n    showCursor: true,\n    cursorChar: '|',\n    autoInsertCss: true\n  });\n</script>\n\n<!-- CSS to ensure the cursor stays inline with the text -->\n<style>\n  #typed-text-container {\n    display: inline-block;\n    white-space: nowrap;\n  }\n  \n  .typed-cursor {\n    display: inline;\n    font-size: inherit;\n    color: inherit;\n    opacity: 1;\n    animation: blink 0.7s infinite;\n  }\n\n  @keyframes blink {\n    0% { opacity: 1; }\n    50% { opacity: 0; }\n    100% { opacity: 1; }\n  }\n</style>\n\n<br>\n<br>\n\n<!-- <p>Latest Work</p> -->\n\n<!-- Grid of Latest Work -->\n\n<!-- :::{.grid}\n:::{.g-col-4}\n[![Cost of Sunlight](images/test.png)](https://ligea-alexander.github.io/cost-of-sunlight-story/#BEGIN)\n**The Cost of Sunlight**\n:::\n\n:::{.g-col-4}\n[![Cellar Defenders](images/millinneal on the chase.png)](https://ligea-alexander.github.io/cellar-defenders/)\n**Cellar Defenders**\n:::\n\n:::{.g-col-4}\n[![NYC Spatial Equity](images/nyc_spatial_equity.png)](https://biking-safety-io.vercel.app)\n**Manhattan is the safest place to bike in NYC. What about the rest of New York?**\n::: -->\n\n\n:::{#latest-work}\n:::","srcMarkdownNoYaml":"\n\n<!-- Include the Typed.js library -->\n<script src=\"https://cdn.jsdelivr.net/npm/typed.js@2.0.12\"></script>\n\n<!-- HTML element for displaying the text -->\n<div id=\"typed-text-container\" style=\"width: 100%; text-align: center;\">\n  <span id=\"typed-text\"></span>\n</div>\n\n<!-- Initialize Typed.js -->\n<script>\n  var typed = new Typed('#typed-text', {\n    strings: [\n      \"She is a multi-disciplinary visual storyteller based in NYC.\",\n      // \"She is a human-centered designer based in NYC.\",\n      \"She is a data-person.\",\n      \"She is a burgeoning interactives designer/IxD.\",\n      \"She is an intermediate level German speaker.\",\n      \"She is Trinidadian born and raised (and quite proud of that).\",\n      \"She is super excited to work with you!\"\n    ],\n    typeSpeed: 50,\n    backSpeed: 30,\n    loop: true,\n    showCursor: true,\n    cursorChar: '|',\n    autoInsertCss: true\n  });\n</script>\n\n<!-- CSS to ensure the cursor stays inline with the text -->\n<style>\n  #typed-text-container {\n    display: inline-block;\n    white-space: nowrap;\n  }\n  \n  .typed-cursor {\n    display: inline;\n    font-size: inherit;\n    color: inherit;\n    opacity: 1;\n    animation: blink 0.7s infinite;\n  }\n\n  @keyframes blink {\n    0% { opacity: 1; }\n    50% { opacity: 0; }\n    100% { opacity: 1; }\n  }\n</style>\n\n<br>\n<br>\n\n<!-- <p>Latest Work</p> -->\n\n<!-- Grid of Latest Work -->\n\n<!-- :::{.grid}\n:::{.g-col-4}\n[![Cost of Sunlight](images/test.png)](https://ligea-alexander.github.io/cost-of-sunlight-story/#BEGIN)\n**The Cost of Sunlight**\n:::\n\n:::{.g-col-4}\n[![Cellar Defenders](images/millinneal on the chase.png)](https://ligea-alexander.github.io/cellar-defenders/)\n**Cellar Defenders**\n:::\n\n:::{.g-col-4}\n[![NYC Spatial Equity](images/nyc_spatial_equity.png)](https://biking-safety-io.vercel.app)\n**Manhattan is the safest place to bike in NYC. What about the rest of New York?**\n::: -->\n\n\n:::{#latest-work}\n:::"},"formats":{"html":{"identifier":{"display-name":"HTML","target-format":"html","base-format":"html"},"execute":{"fig-width":7,"fig-height":5,"fig-format":"retina","fig-dpi":96,"df-print":"default","error":false,"eval":true,"cache":null,"freeze":false,"echo":true,"output":true,"warning":true,"include":true,"keep-md":false,"keep-ipynb":false,"ipynb":null,"enabled":null,"daemon":null,"daemon-restart":false,"debug":false,"ipynb-filters":[],"ipynb-shell-interactivity":null,"plotly-connected":true,"engine":"markdown"},"render":{"keep-tex":false,"keep-typ":false,"keep-source":false,"keep-hidden":false,"prefer-html":false,"output-divs":true,"output-ext":"html","fig-align":"default","fig-pos":null,"fig-env":null,"code-fold":"none","code-ov